# Server
SERVER_PORT=3001

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key

# Gausium Robot API (optional — mock data used if missing)
GAUSIUM_CLIENT_ID=your_client_id
GAUSIUM_CLIENT_SECRET=your_client_secret
GAUSIUM_OPEN_ACCESS_KEY=your_access_key_secret
GAUSIUM_ROBOT_SNS=SN1,SN2,SN3

# Pudu Robot API (optional — mock data used if missing)
# Auth is HMAC-SHA1 over app key + app secret (not Bearer token).
PUDU_BASE_URL=https://csu-open-platform.pudutech.com
PUDU_API_KEY=your_pudu_app_key
PUDU_APP_SECRET=your_pudu_app_secret
PUDU_ROBOT_SNS=SN1,SN2
# Set to 0 to silence the per-task diagnostic dump in getPuduTaskList.
# PUDU_DEBUG_TASKS=0
